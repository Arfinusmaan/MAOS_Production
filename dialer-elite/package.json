{
  "name": "maos-elite-dialer",
  "version": "1.0.0",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "concurrently \"npm run dev\" \"npm run electron\"",
    "build": "vite build && electron-builder",
    "build:win": "set CSC_IDENTITY_AUTO_DISCOVERY=false && rmdir /s /q %APPDATA%\\..\\Local\\electron-builder\\Cache\\winCodeSign 2>nul & vite build && electron-builder",
    "preview": "vite preview",
    "electron": "wait-on http://localhost:5174 && cross-env NODE_ENV=development electron ."
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.7",
    "electron-updater": "^6.8.3",
    "framer-motion": "^11.0.8",
    "lucide-react": "^0.344.0",
    "papaparse": "^5.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sonner": "^1.4.3"
  },
  "devDependencies": {
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^29.1.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.maos.elite.dialer",
    "productName": "MAOS Elite Dialer",
    "publish": [
      {
        "provider": "github",
        "owner": "Arfinusmaan",
        "repo": "MAOS_Production"
      }
    ],
    "win": {
      "target": "portable",
      "sign": null,
      "publish": null,
      "signingHashAlgorithms": []
    },
    "mac": false,
    "linux": false,
    "electronDownload": {
      "isVerifyChecksum": false
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ]
  }
}
